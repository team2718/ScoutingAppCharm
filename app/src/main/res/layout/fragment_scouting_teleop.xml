<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".scouting.FragmentScoutingTeleop">

    <LinearLayout
        android:id="@+id/linearLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Firing Speed -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="220dp"
                android:layout_height="wrap_content"
                android:text="@string/TeleFuelRate"
                android:textSize="20sp"
                android:textAlignment="textEnd"
                android:layout_marginEnd="16dp" />

            <RatingBar
                android:id="@+id/fuelRatingBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:numStars="5"
                android:rating="0"
                android:stepSize="1" />
        </LinearLayout>

        <!-- Shooting Accuracy -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="220dp"
                android:layout_height="wrap_content"
                android:text="@string/TeleAccRate"
                android:textSize="20sp"
                android:textAlignment="textEnd"
                android:layout_marginEnd="16dp" />

            <RatingBar
                android:id="@+id/accRatingBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:numStars="5"
                android:rating="0"
                android:stepSize="1" />
        </LinearLayout>

        <!-- Passing/Shoveling with Performed? checkbox -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="220dp"
                android:layout_height="wrap_content"
                android:text="@string/telePassRate"
                android:textSize="20sp"
                android:textAlignment="textEnd"
                android:layout_marginEnd="16dp" />

            <CheckBox
                android:id="@+id/passCheckBox"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/teleop_checkbox_performed"
                android:textSize="16sp"
                android:checked="false"
                android:layout_marginEnd="8dp" />

            <RatingBar
                android:id="@+id/passRatingBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:enabled="false"
                android:numStars="5"
                android:rating="0"
                android:stepSize="1" />
        </LinearLayout>

        <!-- Defense with Performed? checkbox -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="220dp"
                android:layout_height="wrap_content"
                android:text="@string/teleDefenseRate"
                android:textSize="20sp"
                android:textAlignment="textEnd"
                android:layout_marginEnd="16dp" />

            <CheckBox
                android:id="@+id/defCheckBox"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/teleop_checkbox_performed"
                android:textSize="16sp"
                android:checked="false"
                android:layout_marginEnd="8dp" />

            <RatingBar
                android:id="@+id/defRatingBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:enabled="false"
                android:numStars="5"
                android:rating="0"
                android:stepSize="1" />
        </LinearLayout>

        <!-- Zone Traversal -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="220dp"
                android:layout_height="wrap_content"
                android:text="@string/teleZoneTraversal"
                android:textSize="20sp"
                android:textAlignment="textEnd"
                android:layout_marginEnd="16dp" />

            <CheckBox
                android:id="@+id/rampCheckBox"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/teleRampCheckbox"
                android:textSize="16sp"
                android:checked="false"
                android:layout_marginEnd="16dp" />

            <CheckBox
                android:id="@+id/trenchCheckBox"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/teleTrenchCheckbox"
                android:textSize="16sp"
                android:checked="false" />
        </LinearLayout>

        <!-- Climb -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="220dp"
                android:layout_height="wrap_content"
                android:text="@string/climbSelect"
                android:textSize="20sp"
                android:textAlignment="textEnd"
                android:layout_marginEnd="16dp" />

            <Spinner
                android:id="@+id/climbSpinner"
                android:layout_width="160dp"
                android:layout_height="wrap_content"
                android:entries="@array/climbTypes"
                android:minHeight="48dp"
                android:spinnerMode="dialog" />
        </LinearLayout>

    </LinearLayout>

    <Button
        android:id="@+id/teleopNext"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/next"
        android:textSize="20sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/linearLayout" />

</androidx.constraintlayout.widget.ConstraintLayout>
