<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".scouting.FragmentScoutingAuto">

    <LinearLayout
        android:id="@+id/linearLayout2"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginStart="15dp"
        android:orientation="vertical"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/textView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="25sp" />

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/Aalgae_processor_scored"
            android:layout_width="250dp"
            android:layout_height="50dp"
            android:gravity="center"
            android:hint="@string/Aalgae_processor_scored"
            android:inputType="number" />

        <CheckBox
            android:id="@+id/Adislodged_algae"
            android:layout_width="200dp"
            android:layout_height="50dp"
            android:button="@null"
            android:drawableEnd="?android:attr/listChoiceIndicatorMultiple"
            android:gravity="center"
            android:text="@string/Adislodged_algae"
            android:textSize="20sp" />

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/Afoul"
            android:layout_width="150dp"
            android:layout_height="50dp"
            android:gravity="center"
            android:hint="@string/Afoul"
            android:inputType="number" />

        <Button
            android:id="@+id/L1Scored"
            android:layout_width="40dp"
            android:layout_height="38dp"
            android:layout_marginStart="1dp"
            android:layout_marginBottom="15dp"
            android:text="+"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <LinearLayout
            android:id="@+id/linearLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="visible">

            <TextView
                android:id="@+id/autoText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/auto"
                android:textSize="25sp" />

            <CheckBox
                android:id="@+id/moved"
                android:layout_width="150dp"
                android:layout_height="50dp"
                android:button="@null"
                android:drawableEnd="?android:attr/listChoiceIndicatorMultiple"
                android:gravity="center"
                android:text="@string/Amoved"
                android:textSize="20sp" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/AL1Scored"
                android:layout_width="150dp"
                android:layout_height="50dp"
                android:gravity="center"
                android:hint="@string/AL1Scored"
                android:inputType="number" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/AL2Scored"
                android:layout_width="150dp"
                android:layout_height="50dp"
                android:gravity="center"
                android:hint="@string/AL2Scored"
                android:inputType="number" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/AL3Scored"
                android:layout_width="150dp"
                android:layout_height="50dp"
                android:gravity="center"
                android:hint="@string/AL3Scored"
                android:inputType="number" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/AL4Scored"
                android:layout_width="150dp"
                android:layout_height="50dp"
                android:gravity="center"
                android:hint="@string/AL4Scored"
                android:inputType="number" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/Aalgae_barge_scored"
                android:layout_width="250dp"
                android:layout_height="50dp"
                android:gravity="center"
                android:hint="@string/Aalgae_barge_scored"
                android:inputType="number" />

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>